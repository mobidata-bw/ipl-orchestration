      <virtualTable>
        <name>charge_points</name>
        <sql>-- aggregate max_electric_power per location&#xd;
WITH location_connector_aggregates AS (&#xd;
    SELECT&#xd;
        charging_station.location_id,&#xd;
        MAX(connector.max_electric_power) AS max_electric_power -- max of max_electric_power per location&#xd;
    FROM&#xd;
        charging_station&#xd;
        JOIN evse ON charging_station.id = evse.charging_station_id&#xd;
        JOIN connector ON evse.id = connector.evse_id&#xd;
    GROUP BY&#xd;
        charging_station.location_id&#xd;
),&#xd;
-- aggregate station power and go-live date per location&#xd;
location_station_aggregates AS (&#xd;
    SELECT&#xd;
        location_id,&#xd;
        SUM(max_power_value) AS max_power_value, -- total station power per location&#xd;
        MIN(go_live_date) AS go_live_date -- earliest go-live date per location&#xd;
    FROM&#xd;
        charging_station&#xd;
    GROUP BY&#xd;
        location_id&#xd;
)&#xd;
SELECT&#xd;
    location.id,&#xd;
    location.lat,&#xd;
    location.lon,&#xd;
    location.source,&#xd;
    location.name,&#xd;
    location.address,&#xd;
    location.postal_code,&#xd;
    location.city,&#xd;
    location.state,&#xd;
    location.official_region_code,&#xd;
    location.geometry,&#xd;
    lca.max_electric_power,&#xd;
    lsa.max_power_value,&#xd;
    lsa.go_live_date,&#xd;
    cp.chargepoint_available_count,&#xd;
    cp.chargepoint_unknown_count,&#xd;
    cp.chargepoint_static_count,&#xd;
    cp.chargepoint_charging_count,&#xd;
    cp.chargepoint_inoperative_count,&#xd;
    cp.chargepoint_outoforder_count,&#xd;
    cp.chargepoint_reserved_count,&#xd;
    cp.chargepoint_bike_count,&#xd;
    business.name AS operator_name&#xd;
FROM&#xd;
    location &#xd;
    -- count charge points per status and aggregate for each location&#xd;
    LEFT JOIN (&#xd;
        SELECT&#xd;
            cs.location_id,&#xd;
            SUM(&#xd;
                CASE&#xd;
                    WHEN es.status = &apos;AVAILABLE&apos; THEN 1&#xd;
                    ELSE 0&#xd;
                END&#xd;
            ) AS chargepoint_available_count,&#xd;
            SUM(&#xd;
                CASE&#xd;
                    WHEN es.status = &apos;UNKNOWN&apos; THEN 1&#xd;
                    ELSE 0&#xd;
                END&#xd;
            ) AS chargepoint_unknown_count,&#xd;
            SUM(&#xd;
                CASE&#xd;
                    WHEN es.status = &apos;STATIC&apos; THEN 1&#xd;
                    ELSE 0&#xd;
                END&#xd;
            ) AS chargepoint_static_count,&#xd;
            SUM(&#xd;
                CASE&#xd;
                    WHEN es.status = &apos;CHARGING&apos; THEN 1&#xd;
                    ELSE 0&#xd;
                END&#xd;
            ) AS chargepoint_charging_count,&#xd;
            SUM(&#xd;
                CASE&#xd;
                    WHEN es.status = &apos;INOPERATIVE&apos; THEN 1&#xd;
                    ELSE 0&#xd;
                END&#xd;
            ) AS chargepoint_inoperative_count,&#xd;
            SUM(&#xd;
                CASE&#xd;
                    WHEN es.status = &apos;OUTOFORDER&apos; THEN 1&#xd;
                    ELSE 0&#xd;
                END&#xd;
            ) AS chargepoint_outoforder_count,&#xd;
            SUM(&#xd;
                CASE&#xd;
                    WHEN es.status = &apos;RESERVED&apos; THEN 1&#xd;
                    ELSE 0&#xd;
                END&#xd;
            ) AS chargepoint_reserved_count,&#xd;
            SUM(&#xd;
                CASE&#xd;
                    WHEN es.parking_restrictions &amp; 64 = 64 THEN 1&#xd;
                    ELSE 0&#xd;
                END&#xd;
            ) AS chargepoint_bike_count&#xd;
        FROM&#xd;
            charging_station cs&#xd;
            JOIN evse es ON cs.id = es.charging_station_id&#xd;
        GROUP BY&#xd;
            cs.location_id&#xd;
    ) AS cp ON cp.location_id = location.id &#xd;
    -- join location_connector_aggregates and location_station_aggregates &#xd;
    --to get max_electric_power, max_power_value and go_live_date per location&#xd;
    JOIN location_connector_aggregates lca ON lca.location_id = location.id&#xd;
    JOIN location_station_aggregates lsa ON lsa.location_id = location.id &#xd;
    -- join business to get operator name&#xd;
    JOIN business ON location.operator_id = business.id
</sql>
